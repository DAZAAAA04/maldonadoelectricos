---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>

		<!-- LOGO -->
		<a href="/" class="logo">

			<img src="/favicon.jpeg" alt="Logo" class="logo-image" />

			<div class="logo-text">
				<span class="logo-top">MALDONADO</span>
				<span class="logo-bottom">ELÉCTRICOS ⚡</span>
			</div>

		</a>

		<!-- LINKS -->
		<div class="internal-links">
			<HeaderLink href="/">Servicios</HeaderLink>
			<HeaderLink href="/blog">Nosotros</HeaderLink>
			<HeaderLink href="/about">Contacto</HeaderLink>
		</div>

		<!-- CTA -->
		<div class="right-section">
			<a
				href="mailto:maldonadoelectricos@gmail.com"
				class="email-btn"
			>
				maldonadoelectricos@gmail.com
			</a>
		</div>

	</nav>
</header>

<style>

	header {
		position: sticky;
		top: 0;
		z-index: 1000;

		padding: 1rem 2rem;

		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(10px);

		border-bottom: 1px solid rgba(0, 0, 0, 0.06);
	}

	nav {
		max-width: 1280px;
		margin: 0 auto;

		display: flex;
		align-items: center;
		justify-content: space-between;

		gap: 2rem;
	}

	/* LOGO */

	.logo {
		display: flex;
		align-items: center;
		gap: 1rem;

		text-decoration: none;
	}

	.logo-image {
		width: 58px;
		height: 58px;

		object-fit: cover;

		border-radius: 14px;

		box-shadow:
			0 8px 25px rgba(0,0,0,0.08);
	}

	.logo-text {
		display: flex;
		flex-direction: column;
		line-height: 1;
	}

	.logo-top {
		font-size: 1.3rem;
		font-weight: 800;
		letter-spacing: 1px;

		color: #111827;
	}

	.logo-bottom {
		font-size: 1.1rem;
		font-weight: 600;

		color: #f59e0b;

		margin-top: 0.3rem;
	}

	/* LINKS */

	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.internal-links a {
		position: relative;

		text-decoration: none;

		color: #374151;
		font-weight: 500;

		padding: 0.5rem 0;

		transition: 0.3s ease;
	}

	.internal-links a:hover {
		color: #111827;
	}

	.internal-links a::after {
		content: '';

		position: absolute;
		left: 0;
		bottom: -4px;

		width: 0%;
		height: 2px;

		background: #f59e0b;

		border-radius: 999px;

		transition: 0.3s ease;
	}

	.internal-links a:hover::after {
		width: 100%;
	}

	/* RIGHT */

	.right-section {
		display: flex;
		align-items: center;
	}

	.email-btn {
		padding: 0.9rem 1.4rem;

		border-radius: 999px;

		background: #111827;
		color: white;

		text-decoration: none;

		font-size: 0.9rem;
		font-weight: 500;

		transition: 0.3s ease;

		box-shadow:
			0 10px 25px rgba(17, 24, 39, 0.15);
	}

	.email-btn:hover {
		background: #1f2937;
		transform: translateY(-2px);
	}

	/* MOBILE */

	@media (max-width: 768px) {

		.internal-links {
			display: none;
		}

		.email-btn {
			display: none;
		}

		header {
			padding: 1rem;
		}

		.logo-image {
			width: 48px;
			height: 48px;
		}

		.logo-top {
			font-size: 1rem;
		}

		.logo-bottom {
			font-size: 0.9rem;
		}
	}

</style>