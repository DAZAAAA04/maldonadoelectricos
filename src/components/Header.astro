---
import HeaderLink from './HeaderLink.astro';
import { Zap, Phone, Menu } from 'lucide-react';

const navItems = [
	{ href: '/', label: 'Servicios' },
	{ href: '/nosotros', label: 'Nosotros' },
	{ href: '/proyectos', label: 'Proyectos' },
	{ href: '/contacto', label: 'Contacto' },
];
---

<header class="header">
	<div class="container">

		<!-- LOGO -->
		<a href="/" class="logo">
			<div class="logo-icon">
				<Zap size={20} />
			</div>

			<div class="logo-text">
				<span class="title">ElectroMax</span>
				<span class="subtitle">Soluciones eléctricas</span>
			</div>
		</a>

		<!-- NAV -->
		<nav class="desktop-nav">
			{
				navItems.map((item) => (
					<HeaderLink href={item.href}>
						{item.label}
					</HeaderLink>
				))
			}
		</nav>

		<!-- ACTIONS -->
		<div class="actions">

			<a href="tel:+34123456789" class="phone-btn">
				<Phone size={16} />
				<span>+34 123 456 789</span>
			</a>

			<button class="mobile-menu">
				<Menu size={22} />
			</button>

		</div>
	</div>
</header>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 999;
		width: 100%;
		padding: 1rem 2rem;
		backdrop-filter: blur(12px);
		background: rgba(255, 255, 255, 0.85);
		border-bottom: 1px solid rgba(0,0,0,0.06);
	}

	.container {
		max-width: 1280px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	/* LOGO */

	.logo {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		text-decoration: none;
	}

	.logo-icon {
		width: 46px;
		height: 46px;
		border-radius: 14px;
		background: linear-gradient(135deg, #facc15, #f59e0b);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #111827;
		box-shadow:
			0 10px 25px rgba(245, 158, 11, 0.25);
	}

	.logo-text {
		display: flex;
		flex-direction: column;
	}

	.title {
		font-size: 1rem;
		font-weight: 700;
		color: #111827;
		line-height: 1;
	}

	.subtitle {
		font-size: 0.78rem;
		color: #6b7280;
		margin-top: 3px;
	}

	/* NAV */

	.desktop-nav {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.desktop-nav a {
		position: relative;
		text-decoration: none;
		color: #374151;
		font-weight: 500;
		padding: 0.5rem 0;
		transition: 0.3s ease;
	}

	.desktop-nav a:hover {
		color: #111827;
	}

	.desktop-nav a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -4px;
		width: 0%;
		height: 2px;
		background: #f59e0b;
		transition: 0.3s ease;
		border-radius: 999px;
	}

	.desktop-nav a:hover::after {
		width: 100%;
	}

	/* ACTIONS */

	.actions {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.phone-btn {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		background: #111827;
		color: white;
		text-decoration: none;
		padding: 0.85rem 1.2rem;
		border-radius: 999px;
		font-size: 0.92rem;
		font-weight: 500;
		transition: 0.3s ease;
		box-shadow:
			0 8px 20px rgba(17, 24, 39, 0.15);
	}

	.phone-btn:hover {
		transform: translateY(-2px);
		background: #1f2937;
	}

	.mobile-menu {
		display: none;
		border: none;
		background: transparent;
		cursor: pointer;
		color: #111827;
	}

	/* MOBILE */

	@media (max-width: 900px) {

		.desktop-nav {
			display: none;
		}

		.phone-btn {
			display: none;
		}

		.mobile-menu {
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.header {
			padding: 1rem;
		}

		.container {
			gap: 1rem;
		}
	}
</style>