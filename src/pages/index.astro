---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="es">
<head>
	<BaseHead
		title="Servicios | Maldonado Eléctricos"
		description={SITE_DESCRIPTION}
	/>
</head>

<body>

	<Header />

	<main>

		<!-- HERO -->
		<section class="hero">

			<div class="hero-left">

				<span class="badge">
					Ingeniería • Energía • Automatización
				</span>

				<h1>
					Soluciones eléctricas industriales
					con estándares internacionales
				</h1>

				<p>
					Maldonado Eléctricos S.A.S ofrece diseño,
					construcción y gerencia de proyectos eléctricos,
					automatización industrial y energías renovables.
				</p>

				<div class="hero-buttons">
					<a href="/contacto" class="primary-btn">
						Solicitar cotización
					</a>

					<a href="/proyectos" class="secondary-btn">
						Ver proyectos
					</a>
				</div>

				<!-- STATS -->
				<div class="stats">

					<div class="stat-card">
						<h3>5+</h3>
						<span>Años de experiencia</span>
					</div>

					<div class="stat-card">
						<h3>100+</h3>
						<span>Proyectos ejecutados</span>
					</div>

					<div class="stat-card">
						<h3>24/7</h3>
						<span>Soporte técnico</span>
					</div>

				</div>

			</div>

			<div class="hero-right">

				<img
					src="https://images.unsplash.com/photo-1509391366360-2e959784a276?q=80&w=1200&auto=format&fit=crop"
					alt="Ingeniería eléctrica"
				/>

			</div>

		</section>

		<!-- SERVICES -->
		<section class="services">

			<div class="section-title">
				<span>NUESTROS SERVICIOS</span>
				<h2>Especialistas en ingeniería eléctrica</h2>
			</div>

			<div class="services-grid">

				<div class="service-card">
					<div class="icon">⚡</div>
					<h3>Diseños Eléctricos</h3>
					<p>
						Diseño conceptual, básico y detallado
						para sistemas eléctricos industriales,
						comerciales y residenciales.
					</p>
				</div>

				<div class="service-card">
					<div class="icon">🔋</div>
					<h3>Energía Solar</h3>
					<p>
						Sistemas de energía renovable
						sincronizados con la red eléctrica.
					</p>
				</div>

				<div class="service-card">
					<div class="icon">🏗️</div>
					<h3>Construcción y Montaje</h3>
					<p>
						Montaje de subestaciones,
						tableros eléctricos y sistemas
						de automatización industrial.
					</p>
				</div>

				<div class="service-card">
					<div class="icon">🛠️</div>
					<h3>Mantenimiento</h3>
					<p>
						Mantenimiento preventivo y correctivo
						para sistemas eléctricos industriales.
					</p>
				</div>

				<div class="service-card">
					<div class="icon">📡</div>
					<h3>Cableado Estructurado</h3>
					<p>
						Implementación de redes voz y datos
						con estándares de alta calidad.
					</p>
				</div>

				<div class="service-card">
					<div class="icon">📊</div>
					<h3>Gerencia de Proyectos</h3>
					<p>
						Gestión integral bajo metodologías PMI
						para asegurar calidad y cumplimiento.
					</p>
				</div>

			</div>

		</section>

		<!-- EXPERIENCE -->
		<section class="experience">

			<div class="experience-image">
				<img
					src="https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=1200&auto=format&fit=crop"
					alt="Proyectos industriales"
				/>
			</div>

			<div class="experience-content">

				<span class="mini-title">
					EXPERIENCIA INDUSTRIAL
				</span>

				<h2>
					Proyectos ejecutados en minería,
					hospitales e industria energética
				</h2>

				<p>
					Hemos participado en proyectos para
					Prodeco, Cemex Colombia, Procaps,
					Sociedad Portuaria y hospitales,
					ejecutando soluciones eléctricas
					de media y baja tensión.
				</p>

				<div class="experience-list">

					<div class="list-item">
						<span>✔</span>
						<p>Subestaciones eléctricas</p>
					</div>

					<div class="list-item">
						<span>✔</span>
						<p>Sistemas de automatización industrial</p>
					</div>

					<div class="list-item">
						<span>✔</span>
						<p>Iluminación inteligente</p>
					</div>

					<div class="list-item">
						<span>✔</span>
						<p>Control y distribución eléctrica</p>
					</div>

				</div>

			</div>

		</section>

		<!-- CTA -->
		<section class="cta">

			<div class="cta-content">

				<h2>
					¿Necesitas una solución eléctrica profesional?
				</h2>

				<p>
					Contáctanos y recibe asesoría especializada
					para tu proyecto industrial o comercial.
				</p>

				<a href="/contacto" class="primary-btn">
					Hablar con un asesor
				</a>

			</div>

		</section>

	</main>

	<Footer />

</body>
</html>

<style>

	body {
		background: #f3f4f6;
		color: #111827;
		font-family: sans-serif;
	}

	main {
		width: 100%;
	}

	/* HERO */

	.hero {
		max-width: 1280px;
		margin: 0 auto;
		padding: 1rem 2rem;

		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		align-items: center;
	}

	.hero-left {
		background: white;
		padding: 3rem;
		border-radius: 32px;
		box-shadow: 0 20px 60px rgba(0,0,0,0.05);
	}

	.badge {
		display: inline-flex;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		background: rgba(245, 158, 11, 0.12);
		color: #d97706;
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 1.5rem;
	}

	.hero h1 {
		font-size: 3.5rem;
		line-height: 1.1;
		margin-bottom: 1.5rem;
	}

	.hero p {
		font-size: 1.05rem;
		line-height: 1.8;
		color: #6b7280;
		margin-bottom: 2rem;
	}

	.hero-buttons {
		display: flex;
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.primary-btn {
		background: #111827;
		color: white;
		padding: 1rem 1.5rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		transition: 0.3s ease;
	}

	.primary-btn:hover {
		transform: translateY(-2px);
	}

	.secondary-btn {
		padding: 1rem 1.5rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		border: 1px solid rgba(0,0,0,0.1);
		color: #111827;
		background: white;
	}

	.hero-right img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 32px;
		min-height: 650px;
	}

	/* STATS */

	.stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.stat-card {
		background: #f9fafb;
		padding: 1.5rem;
		border-radius: 20px;
		text-align: center;
	}

	.stat-card h3 {
		font-size: 2rem;
		margin-bottom: 0.5rem;
	}

	.stat-card span {
		color: #6b7280;
		font-size: 0.9rem;
	}

	/* SERVICES */

	.services {
		max-width: 1280px;
		margin: 0 auto;
		padding: 2rem;
	}

	.section-title {
		margin-bottom: 3rem;
	}

	.section-title span {
		color: #d97706;
		font-weight: 700;
		font-size: 0.9rem;
	}

	.section-title h2 {
		font-size: 2.5rem;
		margin-top: 1rem;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.service-card {
		background: white;
		padding: 2rem;
		border-radius: 28px;
		box-shadow: 0 10px 30px rgba(0,0,0,0.04);
		transition: 0.3s ease;
	}

	.service-card:hover {
		transform: translateY(-5px);
	}

	.icon {
		font-size: 2rem;
		margin-bottom: 1rem;
	}

	.service-card h3 {
		margin-bottom: 1rem;
		font-size: 1.2rem;
	}

	.service-card p {
		color: #6b7280;
		line-height: 1.7;
	}

	/* EXPERIENCE */

	.experience {
		max-width: 1280px;
		margin: 0 auto;
		padding: 5rem 2rem;

		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.experience-image img {
		width: 100%;
		border-radius: 32px;
		height: 650px;
		object-fit: cover;
	}

	.mini-title {
		color: #d97706;
		font-weight: 700;
		font-size: 0.9rem;
	}

	.experience-content h2 {
		font-size: 3rem;
		margin: 1rem 0 1.5rem;
		line-height: 1.2;
	}

	.experience-content p {
		color: #6b7280;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.experience-list {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.list-item {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: white;
		padding: 1rem 1.5rem;
		border-radius: 20px;
	}

	/* CTA */

	.cta {
		padding: 5rem 2rem;
	}

	.cta-content {
		max-width: 1000px;
		margin: 0 auto;
		background: #111827;
		color: white;
		padding: 4rem;
		border-radius: 40px;
		text-align: center;
	}

	.cta-content h2 {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.cta-content p {
		color: rgba(255,255,255,0.7);
		margin-bottom: 2rem;
		font-size: 1.05rem;
	}

	/* MOBILE */

	@media (max-width: 900px) {

		.hero,
		.experience {
			grid-template-columns: 1fr;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}

		.hero h1,
		.experience-content h2,
		.cta-content h2 {
			font-size: 2.2rem;
		}

		.stats {
			grid-template-columns: 1fr;
		}

		.hero-buttons {
			flex-direction: column;
		}

		.hero-right img,
		.experience-image img {
			min-height: auto;
			height: 400px;
		}

		.hero-left,
		.cta-content {
			padding: 2rem;
		}
	}

</style>